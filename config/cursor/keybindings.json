[
  {
    "key": "ctrl+p",
    "command": "workbench.action.quickOpenSelectPrevious",
    "when": "inQuickOpen"
  },
  {
    "key": "ctrl+n",
    "command": "workbench.action.quickOpenSelectNext",
    "when": "inQuickOpen"
  },
  {
    "key": "ctrl+p",
    "command": "showPrevParameterHint",
    "when": "editorFocus && parameterHintsMultipleSignatures && parameterHintsVisible"
  },
  {
    "key": "ctrl+n",
    "command": "showNextParameterHint",
    "when": "editorFocus && parameterHintsMultipleSignatures && parameterHintsVisible"
  },
  {
    "key": "ctrl+p",
    "command": "selectPrevSuggestion",
    "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus || suggestWidgetVisible && textInputFocus && !suggestWidgetHasFocusedSuggestion"
  },
  {
    "key": "ctrl+n",
    "command": "selectNextSuggestion",
    "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus || suggestWidgetVisible && textInputFocus && !suggestWidgetHasFocusedSuggestion"
  },
  // Navigating within a group
  {
    "key": "alt+e",
    "command": "workbench.action.previousEditor"
  },
  {
    "key": "alt+r",
    "command": "workbench.action.nextEditor"
  },
  {
    "key": "alt+shift+,",
    "command": "workbench.action.moveEditorLeftInGroup"
  },
  {
    "key": "alt+shift+.",
    "command": "workbench.action.moveEditorRightInGroup"
  },
    // Left: navigateLeft is context-aware — from the auxiliary bar it lands
    // in the editor, from a middle editor group it moves one group left.
    // Unconditional so it also fires when the chat input has editorTextFocus.
    {
      "key": "cmd+ctrl+h",
      "command": "workbench.action.navigateLeft"
    },
    // Right: from the editor jump into the Cursor chat in the auxiliary bar
    // when it's visible; otherwise navigate one group right.
    {
      "key": "cmd+ctrl+l",
      "command": "workbench.action.focusAuxiliaryBar",
      "when": "editorFocus && auxiliaryBarVisible"
    },
    {
      "key": "cmd+ctrl+l",
      "command": "workbench.action.navigateRight",
      "when": "!auxiliaryBarFocus && !(editorFocus && auxiliaryBarVisible)"
    },
    {
      "key": "cmd+ctrl+k",
      "command": "workbench.action.navigateUp"
    },
    // Down: jump into terminal/panel when in the editor; otherwise navigate.
    {
      "key": "cmd+ctrl+j",
      "command": "workbench.action.focusPanel",
      "when": "panelVisible && !panelFocus && editorFocus"
    },
    {
      "key": "cmd+ctrl+j",
      "command": "workbench.action.navigateDown"
    },
    // Toggle the integrated terminal from anywhere. toggleTerminal is smart:
    // hidden → show+focus an existing terminal (no new one is created);
    // visible+focused → hide; visible+unfocused → focus.
    // Overrides Cursor's default ctrl+` (which spawns a fresh terminal).
    {
      "key": "ctrl+`",
      "command": "workbench.action.terminal.toggleTerminal"
    },
    {
      "key": "ctrl+`",
      "command": "-workbench.action.terminal.new"
    },
    // Close the active terminal split (cmd+w mirrors macOS "close" semantics
    // but only fires when the terminal is focused, so editor cmd+w still works).
    {
      "key": "cmd+w",
      "command": "workbench.action.terminal.kill",
      "when": "terminalFocus"
    },
    // Toggle the Cursor chat/Composer panel from the terminal.
    // The terminal swallows these keystrokes by default; commandsToSkipShell
    // in settings.json lets them bubble up to the workbench.
    //
    // cmd+i:
    //   - If the auxiliary bar (chat pane) is already visible, close it.
    //   - If it's hidden, open it AND focus the chat input so you can type
    //     immediately. We chain toggle + focus via runCommands; focusing the
    //     aux bar activates its current view, which puts the cursor in the
    //     chat input.
    // cmd+shift+i: always start a brand-new chat (aichat.newchataction both
    //   opens the panel and focuses the input).
    {
      "key": "cmd+i",
      "command": "workbench.action.toggleAuxiliaryBar",
      "when": "terminalFocus && auxiliaryBarVisible"
    },
    {
      "key": "cmd+i",
      "command": "runCommands",
      "args": {
        "commands": [
          "workbench.action.toggleAuxiliaryBar",
          "workbench.action.focusAuxiliaryBar"
        ]
      },
      "when": "terminalFocus && !auxiliaryBarVisible"
    },
    {
      "key": "cmd+shift+i",
      "command": "aichat.newchataction",
      "when": "terminalFocus"
    },
  // Navigating the file explorer
  {
    "key": "cmd+n",
    "command": "explorer.newFile",
    "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "alt+cmd+n",
    "command": "explorer.newFolder",
    "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "r",
    "command": "renameFile",
    "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "d",
    "command": "deleteFile",
    "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "x",
    "command": "filesExplorer.cut",
    "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "y",
    "command": "filesExplorer.copy",
    "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !inputFocus"
  },
  {
    "key": "p",
    "command": "filesExplorer.paste",
    "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceReadonly && !inputFocus"
  },
  // Positioning the panel/terminal
  {
    "key": "ctrl+k ctrl+h",
    "command": "workbench.action.positionPanelLeft"
  },
  {
    "key": "ctrl+k ctrl+j",
    "command": "workbench.action.positionPanelBottom"
  },
  {
    "key": "ctrl+k ctrl+k",
    "command": "workbench.action.positionPanelTop"
  },
  {
    "key": "ctrl+k ctrl+l",
    "command": "workbench.action.positionPanelRight"
  },
  {
    "key": "ctrl+alt+f",
    "command": "runCommands",
    "args": {
      "commands": [
        "workbench.action.toggleMaximizedPanel",
        "workbench.action.terminal.focus"
      ]
    }
  },
  {
    "key": "ctrl+-",
    "command": "workbench.action.navigateBack",
    "when": "canNavigateBack"
  },
  {
    "key": "ctrl+-",
    "command": "-workbench.action.navigateBack",
    "when": "canNavigateBack"
  },
  {
    "key": "ctrl+=",
    "command": "workbench.action.navigateForward",
    "when": "canNavigateForward"
  },
  {
    "key": "ctrl+shift+-",
    "command": "-workbench.action.navigateForward",
    "when": "canNavigateForward"
  },
  {
    "key": "browserforward",
    "command": "-workbench.action.navigateForward",
    "when": "canNavigateForward"
  },
  {
    "key": "shift+alt+.",
    "command": "references-view.findReferences",
    "when": "editorHasReferenceProvider"
  },
  {
    "key": "shift+alt+f12",
    "command": "-references-view.findReferences",
    "when": "editorHasReferenceProvider"
  },
  {
    "key": "alt+shift+n",
    "command": "search.action.focusNextSearchResult",
    "when": "(hasSearchResult || inSearchEditor) && !inputFocus"
  },
  {
    "key": "ctrl+n",
    "command": "search.action.focusNextSearchResult",
    "when": "hasSearchResult && searchViewletFocus"
  },
  {
    "key": "f4",
    "command": "-search.action.focusNextSearchResult",
    "when": "hasSearchResult || inSearchEditor"
  },
  {
    "key": "alt+shift+p",
    "command": "search.action.focusPreviousSearchResult",
    "when": "(hasSearchResult || inSearchEditor) && searchViewletFocus && !inputFocus"
  },
  {
    "key": "ctrl+p",
    "command": "search.action.focusPreviousSearchResult",
    "when": "hasSearchResult && searchViewletFocus"
  },
  {
    "key": "shift+f4",
    "command": "-search.action.focusPreviousSearchResult",
    "when": "hasSearchResult || inSearchEditor"
  },
  {
    "key": "ctrl+r",
    "command": "-workbench.action.openRecent"
  },
  {
    "key": "shift+cmd+g",
    "command": "workbench.view.scm",
    "when": "workbench.scm.active"
  },
  {
    "key": "ctrl+shift+g",
    "command": "-workbench.view.scm",
    "when": "workbench.scm.active"
  },
  {
    "key": "ctrl+alt+cmd+n",
    "command": "-welcome.showNewFileEntries"
  },
  {
    "key": "ctrl+,",
    "command": "workbench.action.terminal.focusNext",
    "when": "terminalFocus && terminalHasBeenCreated && !terminalEditorFocus || terminalFocus && terminalProcessSupported && !terminalEditorFocus"
  },
  {
    "key": "shift+cmd+]",
    "command": "-workbench.action.terminal.focusNext",
    "when": "terminalFocus && terminalHasBeenCreated && !terminalEditorFocus || terminalFocus && terminalProcessSupported && !terminalEditorFocus"
  },
  {
    "key": "ctrl+.",
    "command": "workbench.action.terminal.focusPrevious",
    "when": "terminalFocus && terminalHasBeenCreated && !terminalEditorFocus || terminalFocus && terminalProcessSupported && !terminalEditorFocus"
  },
  {
    "key": "shift+cmd+[",
    "command": "-workbench.action.terminal.focusPrevious",
    "when": "terminalFocus && terminalHasBeenCreated && !terminalEditorFocus || terminalFocus && terminalProcessSupported && !terminalEditorFocus"
  },
  {
    "key": "ctrl+n",
    "command": "editor.action.scrollDownHover",
    "when": "editorHoverFocused"
  },
  {
    "key": "down",
    "command": "-editor.action.scrollDownHover",
    "when": "editorHoverFocused"
  },
  {
    "key": "ctrl+n",
    "command": "references-view.next",
    "when": "reference-list.hasResult && references-view.canNavigate && references-view.tree.active && !inQuickOpen && !(hasSearchResult || inSearchEditor)"
  },
  {
    "key": "f4",
    "command": "-references-view.next",
    "when": "reference-list.hasResult && references-view.canNavigate"
  },
  {
    "key": "ctrl+p",
    "command": "references-view.prev",
    "when": "reference-list.hasResult && references-view.canNavigate &&  references-view.tree.active && !inQuickOpen && !(hasSearchResult || inSearchEditor)"
  },
  {
    "key": "shift+f4",
    "command": "-references-view.prev",
    "when": "reference-list.hasResult & references-view.canNavigate"
  }
]
